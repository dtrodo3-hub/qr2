      color: #1f2937;
    }

    .login-wrap {
      display: flex;
      height: 100vh;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .login-box {
      width: 100%;
      max-width: 360px;
      background: white;
      padding: 28px 24px;
      border-radius: 18px;
      box-shadow: 0 6px 20px rgba(0,0,0,0.08);
      text-align: center;
    }

    .login-box h2 {
      margin: 0 0 10px;
      font-size: 24px;
    }

    .login-box p {
      margin: 0 0 18px;
      color: #6b7280;
      font-size: 14px;
    }

    .login-box input {
      width: 100%;
      padding: 14px 16px;
      font-size: 16px;
      border: 1px solid #d1d5db;
      border-radius: 12px;
      outline: none;
      margin-bottom: 12px;
    }

    .login-box button {
      width: 100%;
      padding: 14px 16px;
      font-size: 16px;
      font-weight: 700;
      border: none;
      border-radius: 12px;
      background: #2563eb;
      color: white;
      cursor: pointer;
    }

    .wrap {
      max-width: 980px;
      margin: 0 auto;
      padding: 20px 14px 40px;
    }

    h1 {
      margin: 0 0 8px;
      font-size: 28px;
    }

    .desc {
      color: #4b5563;
      line-height: 1.6;
      margin-bottom: 16px;
    }

    .topbar {
      position: sticky;
      top: 0;
      z-index: 10;
      background: #f4f7fb;
      padding: 12px 0 14px;
    }

    .search {
      width: 100%;
      padding: 14px 16px;
      border-radius: 14px;
      border: 1px solid #d1d5db;
      background: white;
      font-size: 16px;
      outline: none;
    }

    .count {
      margin: 10px 2px 0;
      color: #6b7280;
      font-size: 14px;
    }

    .list {
      display: grid;
      gap: 12px;
      margin-top: 16px;
    }

    .card {
      background: white;
      border-radius: 18px;
      padding: 16px;
      box-shadow: 0 6px 20px rgba(0,0,0,0.06);
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
    }

    .name {
      font-size: 20px;
      font-weight: 700;
      margin-bottom: 6px;
    }

    .phone {
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 6px;
    }

    .sub {
      color: #6b7280;
      line-height: 1.5;
      white-space: pre-line;
    }

    .btn {
      display: inline-block;
      padding: 12px 16px;
      border-radius: 12px;
      background: #2563eb;
      color: white;
      text-decoration: none;
      font-weight: 700;
      white-space: nowrap;
    }

    @media (max-width:640px) {
      .card {
        flex-direction: column;
        align-items: flex-start;
      }

      .right {
        width: 100%;
      }

      .btn {
        display: block;
        width: 100%;
        text-align: center;
      }
    }
  </style>
